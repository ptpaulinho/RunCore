# Copy to deploy/.env and fill in. NEVER commit deploy/.env (it's gitignored).

# Public URL of your deployment (used in emails, badges, links)
RUNCORE_PUBLIC_URL=https://runcore.example.com

# Domain Caddy should obtain a TLS cert for (just the host, no scheme).
# Use ":80" to serve plain HTTP for local testing without a domain.
RUNCORE_DOMAIN=runcore.example.com

# --- Email (optional) -------------------------------------------------------
# Leave RUNCORE_SMTP_HOST empty to disable email; certification still works.
# Example for an SMTP relay / Gmail app password / SES SMTP credentials:
RUNCORE_SMTP_HOST=
RUNCORE_SMTP_PORT=587
RUNCORE_SMTP_USER=
RUNCORE_SMTP_PASS=
RUNCORE_SMTP_FROM=no-reply@runcore.example.com
RUNCORE_SMTP_TLS=1

# --- Admin (optional) -------------------------------------------------------
# If set, /cloud/tenants management endpoints require X-Admin-Token: <value>
ADMIN_TOKEN=
