<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RunCore Benchmark Report</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #060b18;
  --surface: #0c1428;
  --surface2: #111e38;
  --surface3: #1a2d50;
  --border: rgba(129,140,248,0.12);
  --border-m: rgba(129,140,248,0.25);
  --text: #f1f5f9;
  --text2: #94a3b8;
  --muted: #475569;
  --accent: #818cf8;
  --accent-2: #a78bfa;
  --green: #34d399;
  --red: #f87171;
  --yellow: #fbbf24;
  --blue: #60a5fa;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding: 40px 24px 60px;
}
.container { max-width: 920px; margin: 0 auto; }

/* ── Header ── */
.header {
  text-align: center;
  margin-bottom: 44px;
  padding-bottom: 36px;
  border-bottom: 1px solid var(--border);
}
.logo {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 1.4rem;
  font-weight: 800;
  letter-spacing: -0.5px;
  background: linear-gradient(135deg, #818cf8, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 6px;
}
.logo svg { -webkit-text-fill-color: initial; }
.subtitle { color: var(--text2); font-size: .9rem; margin-bottom: 20px; }
.result-badge {
  display: inline-block;
  margin-top: 4px;
  padding: 10px 40px;
  border-radius: 50px;
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: 3px;
}
.result-pass {
  background: rgba(52,211,153,0.1);
  color: var(--green);
  border: 2px solid rgba(52,211,153,0.3);
  box-shadow: 0 0 24px rgba(52,211,153,0.15);
}
.result-fail {
  background: rgba(248,113,113,0.1);
  color: var(--red);
  border: 2px solid rgba(248,113,113,0.3);
  box-shadow: 0 0 24px rgba(248,113,113,0.15);
}

/* ── Grid ── */
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.card.optimized { border-color: rgba(52,211,153,0.2); }
.card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
.card-header h3 {
  font-size: .7rem;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  font-weight: 700;
}
.tag {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .3px;
}
.tag-optimized { background: rgba(52,211,153,0.1); color: var(--green); border: 1px solid rgba(52,211,153,0.2); }
.tag-baseline { background: rgba(71,85,105,0.2); color: var(--muted); border: 1px solid var(--border); }

.metric {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 9px 0;
  border-bottom: 1px solid rgba(129,140,248,0.06);
}
.metric:last-child { border-bottom: none; }
.metric-label { color: var(--text2); font-size: .88rem; }
.metric-value { font-weight: 700; font-size: .95rem; }
.good { color: var(--green); }
.warn { color: var(--yellow); }

/* ── KPI savings strip ── */
.savings-strip { margin-bottom: 24px; }
.savings-title {
  font-size: .7rem;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  font-weight: 700;
  margin-bottom: 14px;
}
.savings-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
.saving-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px 16px;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(0,0,0,0.25);
}
.saving-item::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, #7c3aed, #6366f1);
}
.saving-value { font-size: 1.9rem; font-weight: 800; color: var(--green); line-height: 1; letter-spacing: -1px; }
.saving-label { font-size: .72rem; color: var(--muted); margin-top: 6px; text-transform: uppercase; letter-spacing: .8px; font-weight: 600; }

/* ── Replacement table ── */
.table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 24px; margin-bottom: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
.table-title { font-size: .7rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); font-weight: 700; margin-bottom: 16px; }
table { width: 100%; border-collapse: collapse; font-size: .84rem; }
thead th {
  text-align: left;
  padding: 8px 12px;
  font-size: .68rem;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--muted);
  border-bottom: 1px solid var(--border);
  font-weight: 700;
}
tbody td { padding: 9px 12px; border-bottom: 1px solid rgba(129,140,248,0.05); vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover td { background: rgba(129,140,248,0.04); }

/* ── Footer ── */
.footer { text-align: center; color: var(--muted); font-size: .78rem; margin-top: 36px; line-height: 2; }
.footer a { color: var(--accent); text-decoration: none; }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header">
    <div class="logo">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#lgh)" stroke-width="2.5">
        <defs><linearGradient id="lgh" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#818cf8"/><stop offset="100%" stop-color="#a78bfa"/></linearGradient></defs>
        <polygon points="13,2 3,14 12,14 11,22 21,10 12,10"/>
      </svg>
      RunCore
    </div>
    <div class="subtitle">AI Agent Runtime Optimization Engine</div>
    <div class="result-badge result-{{ result_class }}">{{ result }}</div>
  </div>

  <!-- Baseline vs Optimized -->
  <div class="grid">
    <div class="card">
      <div class="card-header">
        <h3>Baseline</h3>
        <span class="tag tag-baseline">unoptimized</span>
      </div>
      <div class="metric"><span class="metric-label">Cost (avg)</span><span class="metric-value">${{ "%.4f"|format(baseline.avg_cost) }}</span></div>
      <div class="metric"><span class="metric-label">Tokens (avg)</span><span class="metric-value">{{ baseline.avg_tokens }}</span></div>
      <div class="metric"><span class="metric-label">Tool calls (avg)</span><span class="metric-value">{{ "%.1f"|format(baseline.avg_tool_calls) }}</span></div>
      <div class="metric"><span class="metric-label">Latency (avg)</span><span class="metric-value">{{ "%.0f"|format(baseline.avg_latency_ms) }}ms</span></div>
      <div class="metric"><span class="metric-label">Success rate</span><span class="metric-value">{{ "%.1f"|format(baseline.success_rate * 100) }}%</span></div>
      <div class="metric"><span class="metric-label">Quality score</span><span class="metric-value">{{ "%.3f"|format(baseline.avg_quality_score) }}</span></div>
      <div class="metric"><span class="metric-label">Cost / success</span><span class="metric-value">${{ "%.4f"|format(baseline.cost_per_successful_task) }}</span></div>
    </div>
    <div class="card optimized">
      <div class="card-header">
        <h3>RunCore Optimized</h3>
        <span class="tag tag-optimized">optimized</span>
      </div>
      <div class="metric"><span class="metric-label">Cost (avg)</span><span class="metric-value good">${{ "%.4f"|format(optimized.avg_cost) }}</span></div>
      <div class="metric"><span class="metric-label">Tokens (avg)</span><span class="metric-value good">{{ optimized.avg_tokens }}</span></div>
      <div class="metric"><span class="metric-label">Tool calls (avg)</span><span class="metric-value good">{{ "%.1f"|format(optimized.avg_tool_calls) }}</span></div>
      <div class="metric"><span class="metric-label">Latency (avg)</span><span class="metric-value good">{{ "%.0f"|format(optimized.avg_latency_ms) }}ms</span></div>
      <div class="metric"><span class="metric-label">Success rate</span><span class="metric-value">{{ "%.1f"|format(optimized.success_rate * 100) }}%</span></div>
      <div class="metric"><span class="metric-label">Quality score</span><span class="metric-value">{{ "%.3f"|format(optimized.avg_quality_score) }}</span></div>
      <div class="metric"><span class="metric-label">Cost / success</span><span class="metric-value good">${{ "%.4f"|format(optimized.cost_per_successful_task) }}</span></div>
    </div>
  </div>

  <!-- Savings KPI strip -->
  <div class="savings-strip">
    <div class="savings-title">Savings Summary</div>
    <div class="savings-grid">
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.cost_savings_pct) }}%</div>
        <div class="saving-label">Cost Reduction</div>
      </div>
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.token_reduction_pct) }}%</div>
        <div class="saving-label">Token Reduction</div>
      </div>
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.tool_call_reduction_pct) }}%</div>
        <div class="saving-label">Fewer Tool Calls</div>
      </div>
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.latency_change_pct) }}%</div>
        <div class="saving-label">Latency Reduction</div>
      </div>
    </div>
  </div>

{% if br.replacement_findings %}
  <!-- Replacement opportunities -->
  <div class="table-card">
    <div class="table-title">Replacement Opportunities — tools that could become deterministic code</div>
    <table>
      <thead>
        <tr>
          <th>Tool</th>
          <th>Pattern</th>
          <th>Type</th>
          <th style="text-align:right">Calls</th>
          <th style="text-align:right">Score</th>
        </tr>
      </thead>
      <tbody>
        {% for f in br.replacement_findings %}
        <tr>
          <td style="font-weight:700;color:var(--accent-2)">{{ f.tool }}</td>
          <td style="color:var(--text2)">{{ f.pattern }}</td>
          <td>
            <span style="background:{% if f.pattern_type == 'lookup' %}rgba(96,165,250,0.1){% elif f.pattern_type == 'format' %}rgba(167,139,250,0.1){% elif f.pattern_type == 'validate' %}rgba(52,211,153,0.1){% else %}rgba(71,85,105,0.15){% endif %};color:{% if f.pattern_type == 'lookup' %}#60a5fa{% elif f.pattern_type == 'format' %}#c4b5fd{% elif f.pattern_type == 'validate' %}#34d399{% else %}#94a3b8{% endif %};padding:3px 9px;border-radius:10px;font-size:.73rem;font-weight:700">{{ f.pattern_type or "unknown" }}</span>
          </td>
          <td style="text-align:right;color:var(--muted)">{{ f.call_count }}</td>
          <td style="text-align:right">
            <span style="color:{% if f.replaceability_score >= 0.8 %}var(--green){% elif f.replaceability_score >= 0.6 %}var(--yellow){% else %}var(--red){% endif %};font-weight:700">{{ "%.0f"|format(f.replaceability_score * 100) }}%</span>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}

  <div class="footer">
    Runs: {{ br.runs }} &nbsp;·&nbsp;
    Success delta: {{ "%+.2f"|format(br.success_rate_delta * 100) }}% &nbsp;·&nbsp;
    Quality delta: {{ "%+.3f"|format(br.quality_delta) }} &nbsp;·&nbsp;
    Generated by <a href="/">RunCore</a>
  </div>

</div>
</body>
</html>
