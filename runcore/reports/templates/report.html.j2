<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RunCore Benchmark Report</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f1117; color: #e2e8f0; padding: 32px; }
  .container { max-width: 860px; margin: 0 auto; }
  .header { text-align: center; margin-bottom: 40px; }
  .logo { font-size: 2.4rem; font-weight: 800; color: #7c3aed; letter-spacing: -1px; }
  .logo span { color: #a78bfa; }
  .subtitle { color: #94a3b8; margin-top: 6px; font-size: 0.95rem; }
  .result-badge { display: inline-block; margin-top: 16px; padding: 10px 36px; border-radius: 50px;
    font-size: 1.6rem; font-weight: 700; letter-spacing: 2px; }
  .result-pass { background: #14532d; color: #4ade80; border: 2px solid #16a34a; }
  .result-fail { background: #450a0a; color: #f87171; border: 2px solid #dc2626; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
  .card { background: #1e2333; border: 1px solid #2d3748; border-radius: 12px; padding: 24px; }
  .card h3 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-bottom: 16px; }
  .metric { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #2d3748; }
  .metric:last-child { border-bottom: none; }
  .metric-label { color: #94a3b8; font-size: 0.9rem; }
  .metric-value { font-weight: 600; font-size: 1rem; }
  .savings-card { background: #1e2333; border: 1px solid #2d3748; border-radius: 12px; padding: 24px; margin-bottom: 24px; }
  .savings-card h3 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-bottom: 20px; }
  .savings-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .saving-item { text-align: center; background: #111827; border-radius: 8px; padding: 16px; }
  .saving-value { font-size: 1.8rem; font-weight: 700; color: #4ade80; }
  .saving-label { font-size: 0.75rem; color: #64748b; margin-top: 4px; }
  .footer { text-align: center; color: #475569; font-size: 0.8rem; margin-top: 32px; }
  .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; margin-left: 8px; }
  .tag-optimized { background: #312e81; color: #a5b4fc; }
  .tag-baseline { background: #292524; color: #a8a29e; }
  .warn { color: #fbbf24; }
  .good { color: #4ade80; }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <div class="logo">Run<span>Core</span></div>
    <div class="subtitle">AI Agent Runtime Optimization Engine</div>
    <div class="result-badge result-{{ result_class }}">{{ result }}</div>
  </div>

  <div class="grid">
    <div class="card">
      <h3>Baseline <span class="tag tag-baseline">unoptimized</span></h3>
      <div class="metric"><span class="metric-label">Cost (avg)</span><span class="metric-value">${{ "%.4f"|format(baseline.avg_cost) }}</span></div>
      <div class="metric"><span class="metric-label">Tokens (avg)</span><span class="metric-value">{{ baseline.avg_tokens }}</span></div>
      <div class="metric"><span class="metric-label">Tool calls (avg)</span><span class="metric-value">{{ "%.1f"|format(baseline.avg_tool_calls) }}</span></div>
      <div class="metric"><span class="metric-label">Latency (avg)</span><span class="metric-value">{{ "%.0f"|format(baseline.avg_latency_ms) }}ms</span></div>
      <div class="metric"><span class="metric-label">Success rate</span><span class="metric-value">{{ "%.1f"|format(baseline.success_rate * 100) }}%</span></div>
      <div class="metric"><span class="metric-label">Quality score</span><span class="metric-value">{{ "%.3f"|format(baseline.avg_quality_score) }}</span></div>
      <div class="metric"><span class="metric-label">Cost / success</span><span class="metric-value">${{ "%.4f"|format(baseline.cost_per_successful_task) }}</span></div>
    </div>
    <div class="card">
      <h3>RunCore Optimized <span class="tag tag-optimized">optimized</span></h3>
      <div class="metric"><span class="metric-label">Cost (avg)</span><span class="metric-value good">${{ "%.4f"|format(optimized.avg_cost) }}</span></div>
      <div class="metric"><span class="metric-label">Tokens (avg)</span><span class="metric-value good">{{ optimized.avg_tokens }}</span></div>
      <div class="metric"><span class="metric-label">Tool calls (avg)</span><span class="metric-value good">{{ "%.1f"|format(optimized.avg_tool_calls) }}</span></div>
      <div class="metric"><span class="metric-label">Latency (avg)</span><span class="metric-value good">{{ "%.0f"|format(optimized.avg_latency_ms) }}ms</span></div>
      <div class="metric"><span class="metric-label">Success rate</span><span class="metric-value">{{ "%.1f"|format(optimized.success_rate * 100) }}%</span></div>
      <div class="metric"><span class="metric-label">Quality score</span><span class="metric-value">{{ "%.3f"|format(optimized.avg_quality_score) }}</span></div>
      <div class="metric"><span class="metric-label">Cost / success</span><span class="metric-value good">${{ "%.4f"|format(optimized.cost_per_successful_task) }}</span></div>
    </div>
  </div>

  <div class="savings-card">
    <h3>Savings Summary</h3>
    <div class="savings-grid">
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.cost_savings_pct) }}%</div>
        <div class="saving-label">Cost Reduction</div>
      </div>
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.token_reduction_pct) }}%</div>
        <div class="saving-label">Token Reduction</div>
      </div>
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.tool_call_reduction_pct) }}%</div>
        <div class="saving-label">Fewer Tool Calls</div>
      </div>
      <div class="saving-item">
        <div class="saving-value">{{ "%.1f"|format(br.latency_change_pct) }}%</div>
        <div class="saving-label">Latency Reduction</div>
      </div>
    </div>
  </div>

{% if br.replacement_findings %}
  <div class="savings-card" style="margin-top:0">
    <h3>Replacement Opportunities — tools that could become deterministic code</h3>
    <table style="width:100%;border-collapse:collapse;font-size:.85rem">
      <thead>
        <tr>
          <th style="text-align:left;padding:8px 12px;color:#64748b;border-bottom:1px solid #2d3748">Tool</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;border-bottom:1px solid #2d3748">Pattern</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;border-bottom:1px solid #2d3748">Type</th>
          <th style="text-align:right;padding:8px 12px;color:#64748b;border-bottom:1px solid #2d3748">Calls</th>
          <th style="text-align:right;padding:8px 12px;color:#64748b;border-bottom:1px solid #2d3748">Score</th>
        </tr>
      </thead>
      <tbody>
        {% for f in br.replacement_findings %}
        <tr>
          <td style="padding:8px 12px;font-weight:600;color:#a78bfa;border-bottom:1px solid #1a2035">{{ f.tool }}</td>
          <td style="padding:8px 12px;color:#94a3b8;border-bottom:1px solid #1a2035">{{ f.pattern }}</td>
          <td style="padding:8px 12px;border-bottom:1px solid #1a2035">
            <span style="background:{% if f.pattern_type == 'lookup' %}#1e3a5f{% elif f.pattern_type == 'format' %}#2d1b4e{% elif f.pattern_type == 'validate' %}#1a3d2b{% else %}#1f2937{% endif %};color:{% if f.pattern_type == 'lookup' %}#60a5fa{% elif f.pattern_type == 'format' %}#c4b5fd{% elif f.pattern_type == 'validate' %}#4ade80{% else %}#94a3b8{% endif %};padding:2px 8px;border-radius:4px;font-size:.75rem">{{ f.pattern_type or "unknown" }}</span>
          </td>
          <td style="padding:8px 12px;text-align:right;color:#64748b;border-bottom:1px solid #1a2035">{{ f.call_count }}</td>
          <td style="padding:8px 12px;text-align:right;border-bottom:1px solid #1a2035">
            <span style="color:{% if f.replaceability_score >= 0.8 %}#4ade80{% elif f.replaceability_score >= 0.6 %}#fbbf24{% else %}#f87171{% endif %};font-weight:600">{{ "%.0f"|format(f.replaceability_score * 100) }}%</span>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}

  <div class="footer">
    Runs: {{ br.runs }} &nbsp;·&nbsp;
    Success delta: {{ "%+.2f"|format(br.success_rate_delta * 100) }}% &nbsp;·&nbsp;
    Quality delta: {{ "%+.3f"|format(br.quality_delta) }} &nbsp;·&nbsp;
    Generated by RunCore
  </div>
</div>
</body>
</html>
